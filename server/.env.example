# ─────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────
PORT=5000
NODE_ENV=development
SERVER_URL=http://localhost:5000
# CLIENT_URL — comma-separate multiple origins for CORS
CLIENT_URL=http://localhost:3000

# ─────────────────────────────────────────
# MONGODB ATLAS
# ─────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>

# ─────────────────────────────────────────
# JWT — MUST be 32+ chars, generate fresh per env
# Tip: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ─────────────────────────────────────────
JWT_SECRET=replace_with_random_64_char_hex_string
JWT_EXPIRE=7d

# ─────────────────────────────────────────
# CLOUDINARY
# ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─────────────────────────────────────────
# EMAIL — Gmail App Password
# ─────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_FROM=SocialSaaS <your_gmail@gmail.com>
EMAIL_SENDER_NAME=SocialSaaS
OTP_EXPIRE_MINUTES=10
SUPPORT_ADMIN_EMAIL=admin@socialsaas.com

# ─────────────────────────────────────────
# SOCIAL MEDIA APIs
# ─────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TWITTER_API_KEY=
TWITTER_API_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ─────────────────────────────────────────
# RAZORPAY
# ─────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
